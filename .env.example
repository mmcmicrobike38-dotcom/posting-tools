# Copy to .env for local development. Do not commit real credentials or tokens.
SIMSOFT_AUTH_MODE=service_account
SIMSOFT_SERVICE_ACCOUNT_JSON_PATH=config/service_account.json
SIMSOFT_OAUTH_CLIENT_JSON_PATH=config/oauth_client.json
SIMSOFT_OAUTH_TOKEN_DIR=data/oauth_tokens
SIMSOFT_CACHE_DB_PATH=data/cache/simsoft_cache.sqlite
SIMSOFT_DUPLICATE_HISTORY_PATH=data/duplicate_history.csv
SIMSOFT_POSTED_BATCHES_PATH=data/posted_batches.csv
SIMSOFT_POSTING_LOCKS_PATH=data/posting_locks.json
SIMSOFT_ACCESS_CONTROL_PATH=data/access_control.json
SIMSOFT_LOG_DIR=logs
SIMSOFT_MAX_EXCEL_FILE_MB=50
SIMSOFT_SCAN_CONCURRENCY=4
SIMSOFT_GOOGLE_CONCURRENCY=3
SIMSOFT_GOOGLE_TIMEOUT_MS=30000
SIMSOFT_REQUIRE_USER_OAUTH_FOR_POSTING=false
SIMSOFT_ADMIN_EMAILS=
SIMSOFT_MEMBER_EMAILS=
SIMSOFT_USER_BRANCHES=
SIMSOFT_PYTHON=python
SIMSOFT_CLOUD_ENDPOINT=
VITE_SIMSOFT_CLOUD_ENDPOINT=
SIMSOFT_GEMINI_API_KEY=
SIMSOFT_GEMINI_MODEL=gemini-3.5-flash
