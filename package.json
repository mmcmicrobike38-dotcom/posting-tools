{
    "name": "posting-tools",
    "version": "1.0.0",
    "private": true,
    "description": "Tauri + React + TypeScript desktop app for posting automation.",
    "scripts": {
        "vite:dev": "vite --config vite.config.mjs --configLoader runner --host 127.0.0.1 --port 1420",
        "build:renderer": "vite build --config vite.config.mjs --configLoader runner",
        "tauri": "tauri",
        "tauri:dev": "tauri dev",
        "dev:tauri": "npm run tauri:dev",
        "dev": "npm run tauri:dev",
        "desktop": "npm run tauri:dev",
        "build": "call npm.cmd run lint && call npm.cmd run test && call npm.cmd run typecheck:backend && call npx.cmd vite build --config vite.config.mjs --configLoader runner",
        "build:bridge": ".\\.venv\\Scripts\\python.exe -m PyInstaller --noconfirm --clean --onedir --name simsoft-python-bridge --distpath dist-python --workpath build-python --specpath build-python scripts\\python_bridge.py",
        "test:python": ".\\.venv\\Scripts\\python.exe -m pytest tests -q -p no:cacheprovider",
        "verify": "npm run build && npm run test:python",
        "tauri:build": "npx tauri build",
        "release:updater:win": "powershell -ExecutionPolicy Bypass -File scripts\\build_updater_release.ps1",
        "installer": "powershell -ExecutionPolicy Bypass -File scripts\\build_release.ps1",
        "portable": "powershell -ExecutionPolicy Bypass -File scripts\\make_portable.ps1",
        "release": "npm run installer",
        "package": "npm run release",
        "package:win": "npm run release",
        "doctor": "powershell -ExecutionPolicy Bypass -File scripts\\doctor.ps1",
        "clean": "powershell -ExecutionPolicy Bypass -File scripts\\clean_release.ps1",
        "clean:apply": "powershell -ExecutionPolicy Bypass -File scripts\\clean_release.ps1 -Apply",
        "cleanup:dry-run": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup_generated_artifacts.ps1",
        "cleanup:apply": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup_generated_artifacts.ps1 -Apply",
        "lint": "eslint src tests-ts scripts --ext .ts,.tsx",
        "test": "vitest run --config vitest.config.mjs --configLoader runner",
        "typecheck:backend": "tsc -p tsconfig.backend.json --noEmit",
        "regression:compare": "tsx scripts/regression_compare.ts",
        "audit": "npm audit --audit-level=high",
        "simloans:desktop": "tauri dev --config src-tauri/tauri.simloans.conf.json",
        "simloans:build": "npx tauri build --config src-tauri/tauri.simloans.conf.json",
        "simloans:vite:dev": "vite --config vite.config.mjs --configLoader runner --host 127.0.0.1 --port 1421"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/react-table": "^8.21.3",
        "@tauri-apps/plugin-process": "^2.3.1",
        "@tauri-apps/plugin-updater": "^2.10.1",
        "@vitejs/plugin-react": "^5.0.0",
        "better-sqlite3": "^12.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.0.0",
        "googleapis": "^150.0.0",
        "lucide-react": "^1.17.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.76.1",
        "react-router-dom": "^7.16.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "winston": "^3.17.0",
        "zod": "^4.4.3",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@tauri-apps/api": "^2.11.0",
        "@tauri-apps/cli": "^2.11.2",
        "@types/better-sqlite3": "^7.6.0",
        "@types/node": "^24.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "concurrently": "^9.0.0",
        "cross-env": "^10.0.0",
        "eslint": "^9.0.0",
        "tsx": "^4.20.0",
        "typescript": "^5.8.0",
        "typescript-eslint": "^8.0.0",
        "vite": "^7.0.0",
        "vitest": "^3.0.0",
        "wait-on": "^8.0.0"
    }
}
